<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users list page</title>
</head>
<body>
  <h1>Users List</h1>
  <ul>
    <% for(let i=0; i<users.length; i++) { %>
      <li><%= users[i] %></li>
    <% } %>


    <% if(isLoging) { %>
      <p>You are logged in.</p>
    <% } else { %>
      <p>You are not logged in.</p>
    <% } %>
  </ul>
</body>
</html>